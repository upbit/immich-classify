# Immich connection settings (required)
IMMICH_API_URL=http://localhost:2283
IMMICH_API_KEY=your-immich-api-key

# VLM API settings
VLM_API_URL=http://localhost:8000/v1
VLM_API_KEY=no-key
VLM_MODEL_NAME=your-model-name

# Classification settings
CLASSIFY_DB_PATH=./classify.db
CLASSIFY_CONCURRENCY=1
CLASSIFY_TIMEOUT=60
CLASSIFY_IMAGE_SIZE=thumbnail
CLASSIFY_DEFAULT_PROMPT=foreground_people.py  # Change this to path/to/your_prompt.py
